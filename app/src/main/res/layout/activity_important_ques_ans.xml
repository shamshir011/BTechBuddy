                    app:layout_constraintHorizontal_bias="0.5"
                    app:layout_constraintStart_toEndOf="@+id/cardViewFundamentalMechanical"
                    app:layout_constraintTop_toBottomOf="@+id/cardViewFundamentalElectronics">

                    <androidx.constraintlayout.widget.ConstraintLayout
